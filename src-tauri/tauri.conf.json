{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voice-ka",
  "version": "0.1.7",
  "identifier": "voice-ka01",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "decorations": false,
        "minWidth": 750,
        "minHeight": 400,
        "maxWidth": 1920,
        "maxHeight": 1080,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
